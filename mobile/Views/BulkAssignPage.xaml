<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="ShiftPlanner.Mobile.Views.BulkAssignPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ShiftPlanner.Mobile.ViewModels"
    x:DataType="vm:BulkAssignViewModel"
    Title="Bulk assign">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">
            <Label Text="Bulk assign" Style="{StaticResource PageTitle}" />
            <Label Text="Assign the same shift to many members across a date range." Style="{StaticResource SubtitleLabel}" />

            <Label
                Text="{Binding ErrorMessage}"
                Style="{StaticResource CaptionLabel}"
                TextColor="{StaticResource ShiftLeaveFg}"
                IsVisible="{Binding HasError}" />

            <VerticalStackLayout Spacing="6">
                <Label Text="START DATE" Style="{StaticResource FieldLabel}" />
                <DatePicker Date="{Binding StartDate}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="END DATE" Style="{StaticResource FieldLabel}" />
                <DatePicker Date="{Binding EndDate}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="SHIFT" Style="{StaticResource FieldLabel}" />
                <Picker ItemsSource="{Binding ShiftCodeOptions}" SelectedItem="{Binding SelectedShiftCode}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="MEMBERS" Style="{StaticResource FieldLabel}" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Members}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:SelectableTeamMember">
                            <Grid Padding="0,6" ColumnDefinitions="Auto,*">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" />
                                <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Button Text="Assign" Command="{Binding SubmitCommand}" IsEnabled="{Binding CanSubmit}" />
            <Button Text="Cancel" Style="{StaticResource TextLinkButton}" Command="{Binding CancelCommand}" />

            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" />
            <ActivityIndicator IsRunning="{Binding IsSaving}" IsVisible="{Binding IsSaving}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
