<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="ShiftPlanner.Mobile.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ShiftPlanner.Mobile.ViewModels"
    x:DataType="vm:SettingsViewModel"
    Title="Settings">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="20,16" Spacing="24">

                <VerticalStackLayout Spacing="2">
                    <Label Text="Settings" Style="{StaticResource PageTitle}" />
                    <Label Text="Team settings, tracks, and shift types" Style="{StaticResource SubtitleLabel}" />
                </VerticalStackLayout>

                <Label
                    Text="{Binding ErrorMessage}"
                    Style="{StaticResource CaptionLabel}"
                    TextColor="{StaticResource ShiftLeaveFg}"
                    IsVisible="{Binding HasError}" />

                <!-- Team settings -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="TEAM SETTINGS" Style="{StaticResource FieldLabel}" />

                    <Border Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="TEAM LEAD" Style="{StaticResource FieldLabel}" />
                            <Picker
                                ItemsSource="{Binding TeamMembersForPicker}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedLead}"
                                IsEnabled="{Binding IsAdmin}" />
                            <Label
                                Text="At most one lead per team — picking someone new replaces the current one."
                                Style="{StaticResource CaptionLabel}" />
                            <Button
                                Text="Update lead"
                                Style="{StaticResource GhostButton}"
                                FontSize="14"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsAdmin}"
                                Command="{Binding UpdateLeadCommand}" />

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource LineLight}, Dark={StaticResource LineDark}}" />

                            <Label Text="CO-LEAD (OPTIONAL)" Style="{StaticResource FieldLabel}" />
                            <Picker
                                ItemsSource="{Binding TeamMembersForPicker}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedCoLead}"
                                IsEnabled="{Binding IsAdmin}" />
                            <Label Text="At most one co-lead per team." Style="{StaticResource CaptionLabel}" />
                            <Button
                                Text="Update co-lead"
                                Style="{StaticResource GhostButton}"
                                FontSize="14"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsAdmin}"
                                Command="{Binding UpdateCoLeadCommand}" />

                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource LineLight}, Dark={StaticResource LineDark}}" />

                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="AUTO-APPROVE LEAVE REQUESTS" Style="{StaticResource FieldLabel}" VerticalOptions="Center" />
                                <Switch Grid.Column="1" IsToggled="{Binding AutoApproveLeaveRequests}" IsEnabled="{Binding IsAdmin}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="AUTO-APPROVE SHIFT SWAPS" Style="{StaticResource FieldLabel}" VerticalOptions="Center" />
                                <Switch Grid.Column="1" IsToggled="{Binding AutoApproveShiftSwaps}" IsEnabled="{Binding IsAdmin}" />
                            </Grid>
                            <Button
                                Text="Save"
                                FontSize="14"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsAdmin}"
                                Command="{Binding SaveAutoApproveCommand}" />

                            <Label
                                Text="{Binding TeamSettingsStatus}"
                                Style="{StaticResource CaptionLabel}"
                                TextColor="{AppThemeBinding Light={StaticResource AccentLight}, Dark={StaticResource AccentDark}}"
                                IsVisible="{Binding HasTeamSettingsStatus}" />

                            <ActivityIndicator IsRunning="{Binding IsTeamSettingsBusy}" IsVisible="{Binding IsTeamSettingsBusy}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Managers -->
                <VerticalStackLayout Spacing="10" IsVisible="{Binding IsAdmin}">
                    <Label Text="MANAGERS" Style="{StaticResource FieldLabel}" />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Managers}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:ManagerAssignment">
                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="14">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding PersonName}" Style="{StaticResource ListTitleLabel}" />
                                            <Label Text="{Binding PersonPhone}" Style="{StaticResource CaptionLabel}" />
                                        </VerticalStackLayout>
                                        <Button
                                            Grid.Column="1"
                                            Text="Revoke"
                                            Style="{StaticResource TextLinkButton}"
                                            FontSize="12"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RevokeManagerCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Border Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="ASSIGN A MANAGER" Style="{StaticResource FieldLabel}" />
                            <Label
                                Text="Anyone on a team you administer, found by phone number."
                                Style="{StaticResource CaptionLabel}" />
                            <Entry Text="{Binding ManagerSearchPhone}" Placeholder="Phone number" Keyboard="Telephone" />
                            <Button Text="Search" Style="{StaticResource GhostButton}" HorizontalOptions="Start" Command="{Binding SearchManagerCandidatesCommand}" />
                            <ActivityIndicator IsRunning="{Binding IsManagerSearchBusy}" IsVisible="{Binding IsManagerSearchBusy}" HorizontalOptions="Center" />

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding ManagerCandidates}" Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PersonSearchResult">
                                        <Grid ColumnDefinitions="*,Auto" Padding="0,6">
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="{Binding Name}" Style="{StaticResource ListTitleLabel}" />
                                                <Label Text="{Binding Phone}" Style="{StaticResource CaptionLabel}" />
                                            </VerticalStackLayout>
                                            <Button
                                                Grid.Column="1"
                                                Text="Grant"
                                                Style="{StaticResource TextLinkButton}"
                                                FontSize="12"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GrantManagerCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Button Text="View reports" Style="{StaticResource GhostButton}" HorizontalOptions="Start" Command="{Binding ViewReportsCommand}" />
                </VerticalStackLayout>

                <!-- Tracks -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="TRACKS" Style="{StaticResource FieldLabel}" />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Tracks}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:TrackItemViewModel">
                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="14">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                        <BoxView Grid.Column="0" Color="{Binding SwatchColor}" WidthRequest="14" HeightRequest="14" CornerRadius="7" VerticalOptions="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="{Binding Name}" Style="{StaticResource ListTitleLabel}" />
                                            <Label
                                                Text="{Binding SubtracksLabel}"
                                                Style="{StaticResource CaptionLabel}"
                                                TextColor="{StaticResource AccentLight}">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ManageSubtracksCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </VerticalStackLayout>
                                        <Button
                                            Grid.Column="2"
                                            Text="Delete"
                                            Style="{StaticResource TextLinkButton}"
                                            FontSize="12"
                                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CanEdit}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTrackCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Border Style="{StaticResource CardBorder}" IsVisible="{Binding CanEdit}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="ADD TRACK" Style="{StaticResource FieldLabel}" />
                            <Entry Text="{Binding NewTrackName}" Placeholder="Track name" />
                            <Entry Text="{Binding NewTrackColor}" Placeholder="#2F7D6B" />
                            <Button Text="Add track" Style="{StaticResource GhostButton}" HorizontalOptions="Start" Command="{Binding AddTrackCommand}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" IsVisible="{Binding CanEdit}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="ADD SUBTRACK" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding Tracks}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SubtrackParentTrack}" />
                            <Entry Text="{Binding NewSubtrackName}" Placeholder="Subtrack name" />
                            <Button Text="Add subtrack" Style="{StaticResource GhostButton}" HorizontalOptions="Start" Command="{Binding AddSubtrackCommand}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Shift types -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="SHIFT TYPES" Style="{StaticResource FieldLabel}" />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding ShiftTypes}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShiftTypeItemViewModel">
                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="14">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                        <Border Grid.Column="0" Style="{StaticResource ChipBorderBase}" BackgroundColor="{Binding SwatchColor}" VerticalOptions="Center">
                                            <Label Text="{Binding Code}" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource InkLight}" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="{Binding Name}" Style="{StaticResource ListTitleLabel}" />
                                            <Label Text="{Binding TimeRangeLabel}" Style="{StaticResource CaptionLabel}" />
                                        </VerticalStackLayout>
                                        <Button
                                            Grid.Column="2"
                                            Text="Delete"
                                            Style="{StaticResource TextLinkButton}"
                                            FontSize="12"
                                            IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CanEdit}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteShiftTypeCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Border Style="{StaticResource CardBorder}" IsVisible="{Binding CanEdit}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="ADD SHIFT TYPE" Style="{StaticResource FieldLabel}" />
                            <Entry Text="{Binding NewShiftCode}" Placeholder="Code, e.g. M" />
                            <Entry Text="{Binding NewShiftName}" Placeholder="Name, e.g. Morning" />
                            <Entry Text="{Binding NewShiftColor}" Placeholder="#2F7D6B" />
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="OVERNIGHT" Style="{StaticResource FieldLabel}" VerticalOptions="Center" />
                                <Switch Grid.Column="1" IsToggled="{Binding NewShiftOvernight}" />
                            </Grid>
                            <Button Text="Add shift type" Style="{StaticResource GhostButton}" HorizontalOptions="Start" Command="{Binding AddShiftTypeCommand}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
