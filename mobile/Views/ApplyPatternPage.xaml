<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="ShiftPlanner.Mobile.Views.ApplyPatternPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ShiftPlanner.Mobile.ViewModels"
    x:DataType="vm:ApplyPatternViewModel"
    Title="Apply pattern">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">
            <Label Text="Apply weekly pattern" Style="{StaticResource PageTitle}" />
            <Label Text="Repeats a per-weekday shift choice across the whole month for the selected members." Style="{StaticResource SubtitleLabel}" />

            <Label
                Text="{Binding ErrorMessage}"
                Style="{StaticResource CaptionLabel}"
                TextColor="{StaticResource ShiftLeaveFg}"
                IsVisible="{Binding HasError}" />

            <VerticalStackLayout Spacing="6">
                <Label Text="WEEKDAY PATTERN" Style="{StaticResource FieldLabel}" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding WeekdayRows}" Spacing="6">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:WeekdayPatternRow">
                            <Grid ColumnDefinitions="100,*" Padding="0,4">
                                <Label Grid.Column="0" Text="{Binding DayLabel}" VerticalOptions="Center" />
                                <Picker
                                    Grid.Column="1"
                                    ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ShiftCodeOptions}"
                                    SelectedItem="{Binding SelectedShiftCode}" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="SKIP INACTIVE MEMBERS" Style="{StaticResource FieldLabel}" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding SkipInactive}" />
            </Grid>

            <VerticalStackLayout Spacing="6">
                <Label Text="MEMBERS" Style="{StaticResource FieldLabel}" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Members}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:SelectableTeamMember">
                            <Grid Padding="0,6" ColumnDefinitions="Auto,*">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" />
                                <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Button Text="Apply pattern" Command="{Binding SubmitCommand}" IsEnabled="{Binding CanSubmit}" />
            <Button Text="Cancel" Style="{StaticResource TextLinkButton}" Command="{Binding CancelCommand}" />

            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" />
            <ActivityIndicator IsRunning="{Binding IsSaving}" IsVisible="{Binding IsSaving}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
