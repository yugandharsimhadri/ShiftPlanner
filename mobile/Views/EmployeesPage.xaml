<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="ShiftPlanner.Mobile.Views.EmployeesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ShiftPlanner.Mobile.ViewModels"
    x:DataType="vm:EmployeesViewModel"
    Title="Employees">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ Add" Command="{Binding AddCommand}" IsEnabled="{Binding CanEdit}" />
    </ContentPage.ToolbarItems>

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
        <CollectionView ItemsSource="{Binding Employees}">

            <CollectionView.Header>
                <VerticalStackLayout Padding="20,16,20,12" Spacing="12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Employees" Style="{StaticResource PageTitle}" />
                        <Label Text="Team directory" Style="{StaticResource SubtitleLabel}" />
                    </VerticalStackLayout>

                    <SearchBar Placeholder="Search by name, code, or track" Text="{Binding SearchText}" />

                    <Label
                        Text="{Binding ErrorMessage}"
                        Style="{StaticResource CaptionLabel}"
                        TextColor="{StaticResource ShiftLeaveFg}"
                        IsVisible="{Binding HasError}" />
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:EmployeeListItemViewModel">
                    <Grid Padding="20,10" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="{Binding Name}" Style="{StaticResource ListTitleLabel}" />
                            <Label Text="{Binding Code}" Style="{StaticResource CaptionLabel}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="End">
                            <Label Text="{Binding TrackName}" Style="{StaticResource CaptionLabel}" HorizontalTextAlignment="End" />
                            <Border Style="{StaticResource RoleBadgeBorder}" HorizontalOptions="End" IsVisible="{Binding IsInactive}">
                                <Label Text="Inactive" Style="{StaticResource RoleBadgeLabel}" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="40" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="No employees yet." Style="{StaticResource CaptionLabel}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </RefreshView>
</ContentPage>
