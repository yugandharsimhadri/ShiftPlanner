<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="ShiftPlanner.Mobile.Views.ShiftSwapFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ShiftPlanner.Mobile.ViewModels"
    x:DataType="vm:ShiftSwapFormViewModel"
    Title="Offer a shift">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">
            <Label Text="Offer a shift" Style="{StaticResource PageTitle}" />
            <Label
                Text="Someone else can claim this shift from your upcoming roster. You keep it unless they claim it."
                Style="{StaticResource SubtitleLabel}" />

            <Label
                Text="{Binding ErrorMessage}"
                Style="{StaticResource CaptionLabel}"
                TextColor="{StaticResource ShiftLeaveFg}"
                IsVisible="{Binding HasError}" />

            <VerticalStackLayout Spacing="6">
                <Label Text="YOUR SHIFT" Style="{StaticResource FieldLabel}" />
                <Picker
                    ItemsSource="{Binding UpcomingShifts}"
                    ItemDisplayBinding="{Binding Label}"
                    SelectedItem="{Binding SelectedShift}" />
                <Label
                    Text="No upcoming shifts to offer."
                    Style="{StaticResource CaptionLabel}"
                    IsVisible="{Binding HasNoUpcomingShifts}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="OFFER TO (OPTIONAL)" Style="{StaticResource FieldLabel}" />
                <Picker
                    ItemsSource="{Binding TeamMembersForPicker}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedTarget}" />
                <Label Text="Leave blank to open it to the whole team." Style="{StaticResource CaptionLabel}" />
            </VerticalStackLayout>

            <Button Text="Offer shift" Command="{Binding SubmitCommand}" IsEnabled="{Binding CanSubmit}" />
            <Button Text="Cancel" Style="{StaticResource TextLinkButton}" Command="{Binding CancelCommand}" />

            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" />
            <ActivityIndicator IsRunning="{Binding IsSaving}" IsVisible="{Binding IsSaving}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
