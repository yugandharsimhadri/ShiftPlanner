<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="ShiftPlanner.Mobile.Views.TeamPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ShiftPlanner.Mobile.ViewModels"
    x:DataType="vm:TeamViewModel"
    Title="Team">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="20,16" Spacing="18">

                <VerticalStackLayout Spacing="2">
                    <Label Text="Team" Style="{StaticResource PageTitle}" />
                    <Label Text="Members and roles" Style="{StaticResource SubtitleLabel}" />
                </VerticalStackLayout>

                <Label
                    Text="{Binding ErrorMessage}"
                    Style="{StaticResource CaptionLabel}"
                    TextColor="{StaticResource ShiftLeaveFg}"
                    IsVisible="{Binding HasError}" />

                <Border Style="{StaticResource CardBorder}" IsVisible="{Binding IsAdmin}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="INVITE A MEMBER" Style="{StaticResource FieldLabel}" />
                        <Entry Text="{Binding InviteEmail}" Placeholder="them@example.com" Keyboard="Email" />
                        <Picker ItemsSource="{Binding RoleChoices}" SelectedItem="{Binding InviteRole}" />
                        <Button Text="Invite" Style="{StaticResource GhostButton}" HorizontalOptions="Start" Command="{Binding InviteCommand}" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Members}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:MemberItemViewModel">
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="14">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding Email}" Style="{StaticResource ListTitleLabel}" />
                                    <Label Text="{Binding StatusLabel}" Style="{StaticResource CaptionLabel}" />

                                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                                        <Border Grid.Column="0" Style="{StaticResource RoleBadgeBorder}">
                                            <Label Text="{Binding Role}" Style="{StaticResource RoleBadgeLabel}" />
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource RoleBadgeBorder}">
                                            <Label Text="{Binding LinkedLabel}" Style="{StaticResource RoleBadgeLabel}" />
                                        </Border>
                                    </Grid>

                                    <FlexLayout
                                        Wrap="Wrap"
                                        JustifyContent="Start"
                                        IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsAdmin}">
                                        <Button
                                            Text="Change role"
                                            Style="{StaticResource TextLinkButton}"
                                            FontSize="12"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ChangeRoleCommand}"
                                            CommandParameter="{Binding .}" />
                                        <Button
                                            Text="Link employee"
                                            Style="{StaticResource TextLinkButton}"
                                            FontSize="12"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.LinkEmployeeCommand}"
                                            CommandParameter="{Binding .}" />
                                        <Button
                                            Text="Remove"
                                            Style="{StaticResource TextLinkButton}"
                                            FontSize="12"
                                            TextColor="{StaticResource ShiftLeaveFg}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveCommand}"
                                            CommandParameter="{Binding .}" />
                                    </FlexLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
