<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="ShiftPlanner.Mobile.Views.LeaveRequestFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ShiftPlanner.Mobile.ViewModels"
    x:DataType="vm:LeaveRequestFormViewModel"
    Title="Request leave">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">
            <Label Text="Request leave" Style="{StaticResource PageTitle}" />

            <Label
                Text="{Binding ErrorMessage}"
                Style="{StaticResource CaptionLabel}"
                TextColor="{StaticResource ShiftLeaveFg}"
                IsVisible="{Binding HasError}" />

            <VerticalStackLayout Spacing="6">
                <Label Text="START DATE" Style="{StaticResource FieldLabel}" />
                <DatePicker Date="{Binding StartDate}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="END DATE" Style="{StaticResource FieldLabel}" />
                <DatePicker Date="{Binding EndDate}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="REASON (OPTIONAL)" Style="{StaticResource FieldLabel}" />
                <Editor Text="{Binding Reason}" HeightRequest="80" AutoSize="TextChanges" />
            </VerticalStackLayout>

            <Button Text="Submit request" Command="{Binding SubmitCommand}" IsEnabled="{Binding CanSubmit}" />
            <Button Text="Cancel" Style="{StaticResource TextLinkButton}" Command="{Binding CancelCommand}" />

            <ActivityIndicator IsRunning="{Binding IsSaving}" IsVisible="{Binding IsSaving}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
