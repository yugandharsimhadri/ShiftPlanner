<Window x:Class="ShiftPlanner.Desktop.Views.TrackManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tracks &amp; Subtracks" Height="480" Width="520" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Tracks &amp; Subtracks" FontFamily="{StaticResource DisplayFont}" FontSize="17" Margin="0,0,0,16"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="TRACKS" Style="{StaticResource FieldLabel}"/>
                <ListBox x:Name="TracksList" Height="260" DisplayMemberPath="Name" SelectionChanged="TracksList_SelectionChanged"/>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBox x:Name="NewTrackBox" Width="140" Margin="0,0,8,0"/>
                    <Button Content="Add" Style="{StaticResource ToolbarButton}" Margin="0" Click="AddTrack_Click"/>
                </StackPanel>
                <Button Content="Delete selected track" Style="{StaticResource ToolbarButton}" Margin="0,8,0,0" Click="DeleteTrack_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="SUBTRACKS" Style="{StaticResource FieldLabel}"/>
                <ListBox x:Name="SubtracksList" Height="260" DisplayMemberPath="Name"/>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBox x:Name="NewSubtrackBox" Width="140" Margin="0,0,8,0"/>
                    <Button Content="Add" Style="{StaticResource ToolbarButton}" Margin="0" Click="AddSubtrack_Click"/>
                </StackPanel>
                <Button Content="Delete selected subtrack" Style="{StaticResource ToolbarButton}" Margin="0,8,0,0" Click="DeleteSubtrack_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
