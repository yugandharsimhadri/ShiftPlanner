<Window x:Class="ShiftPlanner.Desktop.Views.EmployeeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee" Height="560" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" Text="New employee" FontFamily="{StaticResource DisplayFont}" FontSize="17" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="FULL NAME" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="NameBox"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="EMPLOYEE ID" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="IdBox" IsReadOnly="True" Background="#EEF1F0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="PHONE" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="PhoneBox"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="EMAIL (OPTIONAL)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="EmailBox"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TRACK" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="TrackCombo" DisplayMemberPath="Name" SelectionChanged="TrackCombo_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SUBTRACK" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="SubtrackCombo" DisplayMemberPath="Name"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ROLE" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="RoleBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="EMPLOYMENT TYPE" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="EmploymentTypeCombo">
                            <ComboBoxItem Content="Full-time"/>
                            <ComboBoxItem Content="Part-time"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="JOIN DATE" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="JoinDatePicker"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="WEEKLY OFF" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="WeeklyOffCombo">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Sunday"/>
                            <ComboBoxItem Content="Monday"/>
                            <ComboBoxItem Content="Tuesday"/>
                            <ComboBoxItem Content="Wednesday"/>
                            <ComboBoxItem Content="Thursday"/>
                            <ComboBoxItem Content="Friday"/>
                            <ComboBoxItem Content="Saturday"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="STATUS" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="StatusCombo">
                    <ComboBoxItem Content="Active"/>
                    <ComboBoxItem Content="Inactive"/>
                </ComboBox>

                <TextBlock Text="NOTES (OPTIONAL)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="NotesBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                <TextBlock x:Name="ErrorText" Foreground="#A5392B" FontSize="12" Margin="0,0,0,8" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="DeleteButton" Grid.Column="0" Content="Delete employee" HorizontalAlignment="Left"
                    Style="{StaticResource ToolbarButton}" Background="{StaticResource AlertBgBrush}"
                    Foreground="{StaticResource AlertBrush}" BorderBrush="{StaticResource AlertBrush}"
                    Margin="0" Visibility="Collapsed" Click="Delete_Click"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource ToolbarButton}" Click="Cancel_Click"/>
                <Button Content="Save employee" Style="{StaticResource PrimaryButton}" Margin="0" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
