<Window x:Class="ShiftPlanner.Desktop.Views.CopyMonthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copy Previous Month" Height="520" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" FontFamily="{StaticResource DisplayFont}" FontSize="17" Margin="0,0,0,14" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="1">
            <RadioButton x:Name="WeekdayRadio" GroupName="pattern" Content="Repeat by weekday pattern (recommended)" IsChecked="True" Margin="0,0,0,8" Checked="Pattern_Changed"/>
            <RadioButton x:Name="ExactDateRadio" GroupName="pattern" Content="Repeat by exact date" Margin="0,0,0,14" Checked="Pattern_Changed"/>
            <CheckBox x:Name="SkipInactiveCheck" Content="Skip employees marked inactive" IsChecked="True" Margin="0,0,0,16" Checked="Pattern_Changed" Unchecked="Pattern_Changed"/>

            <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Entries to copy" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="CountText" DockPanel.Dock="Right" FontFamily="{StaticResource MonoFont}" HorizontalAlignment="Right" FontWeight="Bold"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Flagged for review" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="FlagCountText" DockPanel.Dock="Right" FontFamily="{StaticResource MonoFont}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#A5392B"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <ListBox x:Name="FlagList" Height="160" BorderThickness="0" Background="Transparent"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Style="{StaticResource ToolbarButton}" Click="Cancel_Click"/>
            <Button Content="Copy &amp; review" Style="{StaticResource PrimaryButton}" Margin="0" Click="Copy_Click"/>
        </StackPanel>
    </Grid>
</Window>
