<Window x:Class="ShiftPlanner.Desktop.Views.ExportImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import &amp; Export" Height="480" Width="480" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="HeaderText" FontFamily="{StaticResource DisplayFont}" FontSize="17" Margin="0,0,0,14"/>

        <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent">
            <TabItem Header="Export roster">
                <StackPanel Margin="0,16,0,0">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource InkSoftBrush}" Margin="0,0,0,16"
                               Text="Exports every assigned shift for the month currently shown on the roster grid."/>
                    <Button Content="Export to Excel (.xlsx)" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,0,0,10" Click="ExportExcel_Click"/>
                    <Button Content="Export to CSV" Style="{StaticResource ToolbarButton}" HorizontalAlignment="Left" Click="ExportCsv_Click"/>
                    <TextBlock x:Name="ExportStatusText" Margin="0,16,0,0" FontFamily="{StaticResource MonoFont}" FontSize="11.5" Foreground="{StaticResource InkFaintBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Import employees">
                <StackPanel Margin="0,16,0,0">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource InkSoftBrush}" Margin="0,0,0,12"
                               Text="CSV columns: Name, Phone, Email, Track, Subtrack, Role, EmploymentType, JoinDate, WeeklyOff, Notes. Track must match an existing track name."/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Download template" Style="{StaticResource ToolbarButton}" Click="DownloadTemplate_Click"/>
                        <Button Content="Choose CSV file…" Style="{StaticResource ToolbarButton}" Click="ChooseFile_Click"/>
                    </StackPanel>
                    <ListBox x:Name="ValidationList" Height="180" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"/>
                    <Button x:Name="ImportButton" Content="Import valid rows" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,12,0,0" IsEnabled="False" Click="Import_Click"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
