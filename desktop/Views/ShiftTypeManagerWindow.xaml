<Window x:Class="ShiftPlanner.Desktop.Views.ShiftTypeManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shift Types" Height="440" Width="560" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Shift types" FontFamily="{StaticResource DisplayFont}" FontSize="17" Margin="0,0,0,12"/>

        <DataGrid x:Name="Grid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                  BorderBrush="{StaticResource LineBrush}" BorderThickness="1" RowHeight="32">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="60"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="120"/>
                <DataGridTextColumn Header="Start (HH:mm)" Binding="{Binding StartText}" Width="100"/>
                <DataGridTextColumn Header="End (HH:mm)" Binding="{Binding EndText}" Width="100"/>
                <DataGridTextColumn Header="Color (#hex)" Binding="{Binding Color}" Width="90"/>
                <DataGridCheckBoxColumn Header="Overnight" Binding="{Binding IsOvernight}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Add row" Style="{StaticResource ToolbarButton}" Click="AddRow_Click"/>
            <Button Content="Delete selected" Style="{StaticResource ToolbarButton}" Click="DeleteRow_Click"/>
            <Button Content="Close &amp; save" Style="{StaticResource PrimaryButton}" Margin="0" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
